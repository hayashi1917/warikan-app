# --- ローカル開発用 (docker-compose) ---
MYSQL_ROOT_PASSWORD="your-root-password"
MYSQL_DATABASE="warikan_db"
MYSQL_USER="warikan_user"
MYSQL_PASSWORD="your-password"
DATABASE_URL="mysql+pymysql://warikan_user:your-password@db:3306/warikan_db?charset=utf8mb4"
SESSION_SECRET_KEY="change-me-to-a-random-secret"

# --- Azure デプロイ用 (App Service の「構成」→「アプリケーション設定」で設定) ---
# MYSQL_HOST=<your-server>.mysql.database.azure.com
# MYSQL_PORT=3306
# MYSQL_USER=<your-admin-user>
# MYSQL_PASSWORD=<your-admin-password>
# MYSQL_DATABASE=warikan_db
# SESSION_SECRET_KEY=<strong-random-secret>
